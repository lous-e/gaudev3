{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/[...route]" },
    { "source": "/", "destination": "/ui/human/landing.html" },
    { "source": "/ui/human/landing.html", "destination": "/ui/landing.html" },
    { "source": "/ui/agent/landing.html", "destination": "/ui/landing.html" }
  ]
}
